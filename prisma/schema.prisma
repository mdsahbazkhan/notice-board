generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  EXAM
  EVENT
  GENERAL
}

enum Priority {
  NORMAL
  URGENT
}

model Notice {
  id          Int       @id @default(autoincrement())
  title       String
  body        String
  category    Category
  priority    Priority  @default(NORMAL)
  publishDate DateTime
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}